# sysbench client side of the harness. Debian bookworm-slim is picked
# for its long support window and stable apt archive — pin drift is
# rare and snapshot.debian.org carries historical packages if a
# session needs to be reproduced after a Debian release rolls over.

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        sysbench=1.0.20+ds-5 \
        default-mysql-client=1.1.0 \
        python3=3.11.2-1+b1 \
        jq=1.6-2.1+deb12u1 \
    && rm -rf /var/lib/apt/lists/*

COPY aggregate.py /usr/local/bin/aggregate.py
