# Recipe that produces the configured mysql-server tree for the e2e build.
# Clones mysql-server (pinned to the mysql-8.4.9 tag, matching the mysql:8.4.9
# runtime and the repo's mysql-server submodule) and runs the Boost download +
# cmake configure. .github/workflows/publish-mysql-base.yml builds this image,
# extracts /workspace/{mysql-server,build}, tars it, and uploads it as a GitHub
# Release asset. tests/e2e/Dockerfile then downloads that tarball instead of
# cloning + configuring on every run.
#
# Built in rust:1.95.0-slim so the generated headers match the e2e builder's
# toolchain. Re-published only when this file changes (or on demand).

FROM rust:1.95.0-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      git \
      cmake \
      make \
      clang \
      libclang-dev \
      g++ \
      pkg-config \
      bison \
      libssl-dev \
      libncurses-dev \
      libtirpc-dev \
      zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# build.rs (MYSQL_HANDLER_FROM_SOURCE) reads these to locate the source and the
# cmake-configured build dir; pinning them here decouples the downstream build
# from CARGO_MANIFEST_DIR / WORKDIR.
ENV MYSQL_SOURCE_DIR=/workspace/mysql-server \
    MYSQL_BUILD_DIR=/workspace/build/mysql

# Pinned to the mysql-8.4.9 tag (matches the runtime image and the submodule).
RUN git clone --depth 1 --branch mysql-8.4.9 \
      https://github.com/mysql/mysql-server.git "$MYSQL_SOURCE_DIR"

RUN mkdir -p "$MYSQL_BUILD_DIR" \
    && cd "$MYSQL_BUILD_DIR" \
    && cmake "$MYSQL_SOURCE_DIR" \
        -DDOWNLOAD_BOOST=1 \
        -DWITH_BOOST="$MYSQL_SOURCE_DIR/extra/boost" \
        -DWITHOUT_SERVER=ON \
        -DCMAKE_BUILD_TYPE=Release
