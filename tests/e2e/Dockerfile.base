# Recipe for the configured mysql-server tree that the e2e build compiles
# against (cloned + cmake-configured). Built in rust:1.95.0-slim so the
# generated headers match the e2e builder's toolchain; published as a Release
# asset (see "Updating the E2E build base" in CONTRIBUTING.md).

FROM rust:1.95.0-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      git \
      cmake \
      make \
      clang \
      libclang-dev \
      g++ \
      pkg-config \
      bison \
      libssl-dev \
      libncurses-dev \
      libtirpc-dev \
      zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# build.rs (MYSQL_HANDLER_FROM_SOURCE) reads these to locate the source and the
# cmake-configured build dir; pinning them here decouples the downstream build
# from CARGO_MANIFEST_DIR / WORKDIR.
ENV MYSQL_SOURCE_DIR=/workspace/mysql-server \
    MYSQL_BUILD_DIR=/workspace/build/mysql

# Pinned to the mysql-8.4.9 tag (matches the runtime image and the submodule),
# then verified by commit SHA so a moved tag cannot swap the source under us.
RUN git clone --depth 1 --branch mysql-8.4.9 \
      https://github.com/mysql/mysql-server.git "$MYSQL_SOURCE_DIR" \
    && test "$(git -C "$MYSQL_SOURCE_DIR" rev-parse HEAD)" \
       = f9c88132a87a7d9e740e50bce2621999695bd3fe

RUN mkdir -p "$MYSQL_BUILD_DIR" \
    && cd "$MYSQL_BUILD_DIR" \
    && cmake "$MYSQL_SOURCE_DIR" \
        -DDOWNLOAD_BOOST=1 \
        -DWITH_BOOST="$MYSQL_SOURCE_DIR/extra/boost" \
        -DWITHOUT_SERVER=ON \
        -DCMAKE_BUILD_TYPE=Release
